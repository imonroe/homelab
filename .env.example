# Common settings (shared across all services)
# Timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver
# User / group IDs to run services under. Only services that support dropping
# privileges use these (currently Authelia). Leave empty to use image defaults.
PUID=
PGID=

# MySQL (used by compose.mysql.yml)
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=homelab

# Vaultwarden (used by compose.vaultwarden.yml)
# VAULTWARDEN_DOMAIN must be the full HTTPS URL, e.g. https://vault.example.com
VAULTWARDEN_DOMAIN=https://vault.example.com
# Set to true only during initial setup, then change back to false
VAULTWARDEN_SIGNUPS_ALLOWED=false
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=changeme

# Pi-hole (used by compose.pihole.yml)
# Web admin / API password for the Pi-hole dashboard
PIHOLE_WEBPASSWORD=changeme
# Upstream DNS resolvers, semicolon-delimited (defaults to Cloudflare if unset)
PIHOLE_DNS_UPSTREAMS=1.1.1.1;1.0.0.1
