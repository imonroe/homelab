# Common settings (shared across all services)
# Timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver
# User / group IDs to run services under. Used by services that support it
# (Authelia, Plex, Navidrome). Leave empty to use each image's default; a few
# services (e.g. Navidrome) fall back to 1000 when these are blank.
PUID=
PGID=

# MySQL (used by compose.mysql.yml)
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=homelab

# Vaultwarden (used by compose.vaultwarden.yml)
# VAULTWARDEN_DOMAIN must be the full HTTPS URL, e.g. https://vault.example.com
VAULTWARDEN_DOMAIN=https://vault.example.com
# Set to true only during initial setup, then change back to false
VAULTWARDEN_SIGNUPS_ALLOWED=false
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=changeme

# Pi-hole (used by compose.pihole.yml)
# Web admin / API password for the Pi-hole dashboard
PIHOLE_WEBPASSWORD=changeme
# Upstream DNS resolvers, semicolon-delimited (defaults to Cloudflare if unset)
PIHOLE_DNS_UPSTREAMS=1.1.1.1;1.0.0.1

# Plex (used by compose.plex.yml)
# One-time claim token from https://www.plex.tv/claim (expires ~4 min)
PLEX_CLAIM=
# URL clients use to reach the server (needed for bridge networking)
PLEX_ADVERTISE_IP=https://plex.example.com:443
# Host path to your media library (defaults to ./plex_media)
PLEX_MEDIA_DIR=./plex_media

# n8n (used by compose.n8n.yml)
# Public hostname and full external URL (with trailing slash)
N8N_HOST=n8n.example.com
N8N_WEBHOOK_URL=https://n8n.example.com/
# Protocol and number of reverse proxies in front of n8n (NPM = 1)
N8N_PROTOCOL=https
N8N_PROXY_HOPS=1

# Navidrome (used by compose.navidrome.yml)
# Host path to your music library (defaults to ./navidrome_music)
NAVIDROME_MUSIC_DIR=./navidrome_music
